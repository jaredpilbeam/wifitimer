#!/usr/bin/env bash

echo "wifitimer script is now running... press q to quit."
echo "$(date) wifitimer started" >>wifitimer.log
while [[ $input != "q" ]]; do
  current_time=$(date +%-H%M)
  current_day=$(date +%d)
  current_month=$(date +%m)
  current_year=$(date +%Y)
  current_dayofweek=($(date +%w) + 1)

  if nmcli general status | grep --quiet "full"; then
    STATUS=1
  else
    STATUS=0
  fi

  # Reading each column of schedule.csv into its own array.
  montharray=($(tail -n +2 schedule.csv | cut -d "," -f1))
  dayarray=($(tail -n +2 schedule.csv | cut -d "," -f2))
  yeararray=($(tail -n +2 schedule.csv | cut -d "," -f3))
  dayofweekarray=($(tail -n +2 schedule.csv | cut -d "," -f4))
  starttimearray=($(tail -n +2 schedule.csv | cut -d "," -f5))
  endtimearray=($(tail -n +2 schedule.csv | cut -d "," -f6))

  for i in "${!yeararray[@]}"; do
    year="${yeararray[i]}"
    month="${montharray[i]}"
    day="${dayarray[i]}"
    dayofweek="${dayofweekarray[i]}"
    start="${starttimearray[i]}"
    end="${endtimearray[i]}"
    if ((year == current_year && month == current_month && day == current_day && current_time >= start && current_time < end)); then
      if ((STATUS == 1)); then
        nmcli radio all off
        echo $(date)" networking disabled" >>wifitimer.log
      fi
      DISCONNECTED=1
      break
    fi
    if ((year == 0 && month == 0 && day == 0 && dayofweek == current_dayofweek && current_time >= start && current_time < end)); then
      if ((STATUS == 1)); then
        nmcli radio all off
        echo $(date)" networking disabled" >>wifitimer.log
      fi
      DISCONNECTED=1
      break
    fi
    if ((year == 0 && month == 0 && day == 0 && dayofweek == 0 && current_time >= start && current_time < end)); then
      if ((STATUS == 1)); then
        nmcli radio all off
        echo $(date)" networking disabled" >>wifitimer.log
        sleep 5
      fi
      DISCONNECTED=1
      break
    fi
    DISCONNECTED=0
  done
  if ((DISCONNECTED == 0)); then
    if ((STATUS == 0)); then
      nmcli radio all on
      echo $(date)" networking enabled" >>wifitimer.log
      sleep 5
    fi
  fi
  read -t 1 -n 1 input
done

nmcli radio all on
echo $(date)" networking enabled" >>wifitimer.log
printf "\nQuitting program..."
echo $(date)" program succesfully exited" >>wifitimer.log
